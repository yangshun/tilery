{
  "name": "tilery-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run --filter @tilery/docs dev",
    "build": "vp run --filter './packages/*' build",
    "build:docs": "vp run --filter @tilery/docs build",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "test:coverage": "vp test run --coverage",
    "check": "vp check",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "fmt": "vp fmt . --write",
    "fmt:check": "vp fmt . --check",
    "typecheck": "tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/react/tsconfig.json --noEmit && tsc -p apps/docs/tsconfig.json --noEmit",
    "clean": "rm -rf packages/*/dist apps/*/dist apps/*/.next",
    "release": "pnpm -r --filter tilery --filter @tileryjs/react publish --access public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plugin-dts": "^5.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.11.0"
}
